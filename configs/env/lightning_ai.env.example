# --- Core policy ---
USAGE_SCOPE=INTERNAL_RND
INTERNAL_TAG=INTERNAL_RND
SHARING_ALLOWED=false

# --- Runtime paths on Lightning Studio VM ---
# Use Lightning persistent storage under /teamspace/studios/this_studio/
# AURORA_ROOT must match the checked-out repository path.
AURORA_ROOT=/teamspace/studios/this_studio/spirited-away
DATA_ROOT=/teamspace/studios/this_studio/aurora-data
MODELS_ROOT=/teamspace/studios/this_studio/aurora-models
OUTPUTS_ROOT=/teamspace/studios/this_studio/aurora-outputs
MANIFESTS_ROOT=/teamspace/studios/this_studio/aurora-manifests

# --- Hugging Face ---
# HF_TOKEN must belong to an account that has accepted:
#   - FLUX Non-Commercial License at https://huggingface.co/black-forest-labs/FLUX.2-dev
# Inject via Lightning Secrets UI (recommended) or export in shell session.
# Do NOT commit this file with a real token.
HF_HOME=/teamspace/studios/this_studio/.cache/huggingface
HF_TOKEN=REPLACE_WITH_HUGGINGFACE_TOKEN
HF_MODEL_REGISTRY=configs/models/hf_models.internal_rnd.json

# --- BytePlus ModelArk API (Seedream 5.0 Lite - API-only) ---
# Required for Scenario B pre-processing: real subject -> anime stylization.
# Inject via Lightning Secrets UI. Do NOT commit with a real key.
BYTEPLUS_API_KEY=REPLACE_WITH_BYTEPLUS_API_KEY
BYTEPLUS_SEEDREAM_MODEL_ID=seedream-5-0-260128
BYTEPLUS_API_ENDPOINT=https://ark.ap-southeast.bytepluses.com/api/v3

# --- ComfyUI API ---
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_TIMEOUT_SECONDS=900
COMFYUI_PORT=8188
COMFYUI_ROOT=/teamspace/studios/this_studio/ComfyUI
COMFYUI_REPO_URL=https://github.com/comfyanonymous/ComfyUI.git
COMFYUI_LISTEN_HOST=0.0.0.0
COMFYUI_STARTUP_TIMEOUT_SECONDS=240
COMFYUI_RUNTIME_DIR=/teamspace/studios/this_studio/spirited-away/.runtime
COMFYUI_LOG_FILE=/teamspace/studios/this_studio/spirited-away/.runtime/comfyui.log
COMFYUI_PID_FILE=/teamspace/studios/this_studio/spirited-away/.runtime/comfyui.pid

# --- Lightning venv (optional) ---
LIGHTNING_CREATE_VENV=0
LIGHTNING_VENV_PATH=/teamspace/studios/this_studio/spirited-away/.venv

# --- ComfyUI model file names (relative to their ComfyUI model subdirectories) ---
COMFYUI_UNET_NAME=flux1-dev.safetensors
COMFYUI_T5_ENCODER_NAME=t5xxl_fp8_e4m3fn.safetensors
COMFYUI_CLIP_L_NAME=clip_l.safetensors
COMFYUI_VAE_NAME=ae.safetensors

# --- ComfyUI custom nodes ---
PS_BLEND_NODE_REPO_URL=https://github.com/bluevisor/ComfyUI_PS_Blend_Node.git
SCENARIO_C_EXTRA_NODE_REPOS=

# --- Training (AI Toolkit) ---
AI_TOOLKIT_ROOT=/teamspace/studios/this_studio/ai-toolkit
IDENTITY_TRIGGER_TOKEN=[subj_name_2026]
IDENTITY_DATASET_DIR=/teamspace/studios/this_studio/aurora-data/identity_dataset
IDENTITY_OUTPUT_DIR=/teamspace/studios/this_studio/aurora-models/identity_adapters
TRAIN_STEPS=2500
TRAIN_BATCH_SIZE=2
TRAIN_LEARNING_RATE=0.0001
TRAIN_ADAPTER_RANK=32
TRAIN_WEIGHT_DECAY=0.0001
TRAIN_OPTIMIZER=AdamW8Bit
TRAIN_ENABLE_DOP=true
TRAIN_TIMESTEP_BIAS=balanced
TRAIN_RESOLUTION=1024,1408

# --- LoRA names used in ComfyUI workflows ---
IDENTITY_LORA_NAME=identity_adapter_latest.safetensors
ANIME_LORA_NAME=f2k_anything2real_a.safetensors

# --- Character assets ---
CHARACTER_SOURCE_MANIFEST=configs/characters/spirited_away_sources.internal_rnd.json
CHARACTER_ASSET_OUTPUT_DIR=/teamspace/studios/this_studio/aurora-data/character_refs
CHARACTER_SOURCE_ROOT=/teamspace/studios/this_studio/aurora-data/character_refs_sources

# --- Scenario C runtime contract ---
SCENARIO_C_TRACK=track_c
SCENARIO_C_SUBJECT_IMAGE=input/subject.png
SCENARIO_C_COMPANION_IMAGE_A=input/companion_a.png
SCENARIO_C_COMPANION_IMAGE_B=input/companion_b.png
SCENARIO_C_SUBJECT_MASK_IMAGE=input/subject_mask.png
SCENARIO_C_COMPANION_MASK_IMAGE=input/companion_mask.png
SCENARIO_C_PS_BLEND_MODE=Multiply

# --- Spaces archival (not typically used from Lightning; use DigitalOcean for archival) ---
ENABLE_SPACES_ARCHIVAL=false
DO_SPACES_ACCESS_KEY_ID=REPLACE_WITH_SPACES_ACCESS_KEY_ID
DO_SPACES_SECRET_ACCESS_KEY=REPLACE_WITH_SPACES_SECRET_ACCESS_KEY
DO_SPACES_ARCHIVE_PREFIX=internal-rnd/archives
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=aurora-internal-rnd
DO_SPACES_REGION=nyc3
