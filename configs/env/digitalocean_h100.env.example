# --- Core policy ---
USAGE_SCOPE=INTERNAL_RND
INTERNAL_TAG=INTERNAL_RND
SHARING_ALLOWED=false

# --- DigitalOcean ---
DO_REGION=nyc3
DO_DROPLET_NAME=aurora-h100-01
DO_IMAGE=ubuntu-24-04-x64
DO_SIZE=gpu-h100x1-80gb
DO_SSH_FINGERPRINT=REPLACE_WITH_DIGITALOCEAN_SSH_KEY_FINGERPRINT

# Optional Spaces runtime (non-secret contract keys)
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=aurora-internal-rnd
DO_SPACES_REGION=nyc3

# --- GitHub integration on VM ---
GITHUB_REPO_URL=https://github.com/YOUR_ORG/spirited-away.git
GITHUB_BRANCH=main
GITHUB_SSH_KEY_PATH=/opt/aurora/.ssh/id_ed25519

# --- Runtime paths on VM ---
AURORA_ROOT=/opt/aurora/Aurora-Fotos
DATA_ROOT=/opt/aurora/data
MODELS_ROOT=/opt/aurora/models
OUTPUTS_ROOT=/opt/aurora/outputs
MANIFESTS_ROOT=/opt/aurora/manifests

# --- Hugging Face ---
# HF_TOKEN must belong to an account that has accepted:
#   - FLUX Non-Commercial License at https://huggingface.co/black-forest-labs/FLUX.2-dev
#   - Mistral terms at https://huggingface.co/mistralai/Mistral-Small-3.1-24B-Instruct-2503 (if used)
HF_HOME=/opt/aurora/.cache/huggingface
HF_TOKEN=REPLACE_WITH_HUGGINGFACE_TOKEN
HF_MODEL_REGISTRY=configs/models/hf_models.internal_rnd.json

# --- BytePlus ModelArk API (Seedream 5.0 Lite - API-only, not on HuggingFace) ---
# Required for Scenario B pre-processing: real subject -> anime stylization
# Get your API key at https://www.byteplus.com/en/product/modelark
BYTEPLUS_API_KEY=REPLACE_WITH_BYTEPLUS_API_KEY
BYTEPLUS_SEEDREAM_MODEL_ID=seedream-5-0-260128
BYTEPLUS_API_ENDPOINT=https://ark.ap-southeast.bytepluses.com/api/v3

# --- ComfyUI API ---
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_TIMEOUT_SECONDS=900
COMFYUI_PORT=8188
COMFYUI_ROOT=/opt/aurora/ComfyUI
COMFYUI_REPO_URL=https://github.com/comfyanonymous/ComfyUI.git

# --- ComfyUI model file names (relative to their ComfyUI model subdirectories) ---
# FLUX.2-dev transformer: place flux1-dev.safetensors in ComfyUI/models/diffusion_models/
# T5-XXL: place t5xxl_fp8_e4m3fn.safetensors in ComfyUI/models/text_encoders/
# CLIP-L: place clip_l.safetensors in ComfyUI/models/text_encoders/
# VAE: place ae.safetensors in ComfyUI/models/vae/
# See scripts/models/fetch_hf_models.py --link-to-comfyui for automated setup
COMFYUI_UNET_NAME=flux1-dev.safetensors
COMFYUI_T5_ENCODER_NAME=t5xxl_fp8_e4m3fn.safetensors
COMFYUI_CLIP_L_NAME=clip_l.safetensors
COMFYUI_VAE_NAME=ae.safetensors

# --- ComfyUI custom nodes ---
# PS Blend Node: cloned from GitHub into ComfyUI/custom_nodes/
PS_BLEND_NODE_REPO_URL=https://github.com/bluevisor/ComfyUI_PS_Blend_Node.git
# Aurora custom nodes (TP-Blend wrapper + Flux2MultiReference + ImageStitch) are
# bundled in this repo under custom_nodes/ and linked automatically by install_custom_nodes.sh
# Additional external repos for Scenario C (comma-separated git URLs, optional):
SCENARIO_C_EXTRA_NODE_REPOS=

# --- Training ---
# AI Toolkit path (cloned from https://github.com/ostris/ai-toolkit)
AI_TOOLKIT_ROOT=/opt/aurora/ai-toolkit
IDENTITY_TRIGGER_TOKEN=[subj_name_2026]
IDENTITY_DATASET_DIR=/opt/aurora/data/identity_dataset
IDENTITY_OUTPUT_DIR=/opt/aurora/models/identity_adapters
TRAIN_STEPS=2500
TRAIN_BATCH_SIZE=2
TRAIN_LEARNING_RATE=0.0001
TRAIN_ADAPTER_RANK=32
TRAIN_WEIGHT_DECAY=0.0001
TRAIN_OPTIMIZER=AdamW8Bit
TRAIN_ENABLE_DOP=true
TRAIN_TIMESTEP_BIAS=balanced
TRAIN_RESOLUTION=1024,1408

# --- LoRA names used in ComfyUI workflows ---
# Identity adapter trained by launch_identity_training.py (relative to ComfyUI/models/loras/)
IDENTITY_LORA_NAME=identity_adapter_latest.safetensors
# Anime LoRA for Scenario B composition (from lrzjason/Anything2Real, placed in ComfyUI/models/loras/)
ANIME_LORA_NAME=f2k_anything2real_a.safetensors

# --- Character assets policy ---
CHARACTER_SOURCE_MANIFEST=configs/characters/spirited_away_sources.internal_rnd.json
CHARACTER_ASSET_OUTPUT_DIR=/opt/aurora/data/character_refs
CHARACTER_SOURCE_ROOT=/opt/aurora/data/character_refs_sources

# --- Scenario C runtime contract ---
SCENARIO_C_TRACK=track_c
SCENARIO_C_SUBJECT_IMAGE=input/subject.png
SCENARIO_C_COMPANION_IMAGE_A=input/companion_a.png
SCENARIO_C_COMPANION_IMAGE_B=input/companion_b.png
SCENARIO_C_SUBJECT_MASK_IMAGE=input/subject_mask.png
SCENARIO_C_COMPANION_MASK_IMAGE=input/companion_mask.png
SCENARIO_C_PS_BLEND_MODE=Multiply

# --- Optional Spaces archival (internal only) ---
ENABLE_SPACES_ARCHIVAL=false
DO_SPACES_ACCESS_KEY_ID=REPLACE_WITH_SPACES_ACCESS_KEY_ID
DO_SPACES_SECRET_ACCESS_KEY=REPLACE_WITH_SPACES_SECRET_ACCESS_KEY
DO_SPACES_ARCHIVE_PREFIX=internal-rnd/archives
