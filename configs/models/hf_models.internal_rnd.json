{
    "version": "1.1.0",
    "usage_scope": "INTERNAL_RND",
    "download_policy": {
        "pin_revisions": true,
        "write_lockfile": true
    },
    "models": [
        {
            "alias": "flux2_dev",
            "repo_id": "black-forest-labs/FLUX.2-dev",
            "revision": "main",
            "required": true,
            "local_dir": "base/flux2_dev",
            "gated": true,
            "license_url": "https://huggingface.co/black-forest-labs/FLUX.2-dev",
            "license_note": "FLUX Non-Commercial License. Operator must accept at the URL above while logged in with the HF account whose token is set in HF_TOKEN before this download will succeed.",
            "download": {
                "mode": "snapshot",
                "allow_patterns": [
                    "*.safetensors",
                    "*.json",
                    "*.txt"
                ]
            },
            "comfyui_layout": {
                "transformer": "models/diffusion_models/flux1-dev.safetensors",
                "t5_encoder": "models/text_encoders/t5xxl_fp8_e4m3fn.safetensors",
                "clip_l": "models/text_encoders/clip_l.safetensors",
                "vae": "models/vae/ae.safetensors"
            }
        },
        {
            "alias": "anything2real_2601_a",
            "repo_id": "lrzjason/Anything2Real",
            "revision": "main",
            "required": true,
            "local_dir": "loras/anything2real_2601_a",
            "download": {
                "mode": "snapshot",
                "allow_patterns": [
                    "*.safetensors",
                    "*.json",
                    "*.txt"
                ]
            },
            "comfyui_layout": {
                "lora": "models/loras/f2k_anything2real_a.safetensors"
            }
        },
        {
            "alias": "qwen_image_edit_2511",
            "repo_id": "Qwen/Qwen-Image-Edit-2511",
            "revision": "main",
            "required": true,
            "local_dir": "editors/qwen_image_edit_2511",
            "download": {
                "mode": "snapshot",
                "allow_patterns": [
                    "*.safetensors",
                    "*.json",
                    "*.txt"
                ]
            },
            "usage_note": "Used for Scenario A pre-processing: anime companions -> photoreal via Anything2Real LoRA. Invoked via scripts/pipeline/qwen_anime_to_real.py, not via ComfyUI."
        }
    ],
    "api_only_models": [
        {
            "alias": "seedream_5_lite",
            "provider": "byteplus_modelark",
            "model_id": "seedream-5-0-260128",
            "required_env": "BYTEPLUS_API_KEY",
            "usage_note": "Seedream 5.0 Lite is API-only (BytePlus ModelArk). Not downloadable from HuggingFace. Used for Scenario B pre-processing: real subject -> anime stylization. Invoked via scripts/pipeline/seedream_api_stylize.py.",
            "api_docs": "https://www.byteplus.com/en/blog/seedream5-0-lite"
        }
    ],
    "optional_llm_models": [
        {
            "alias": "mistral_small_3_1_prompt_enricher",
            "repo_id": "mistralai/Mistral-Small-3.1-24B-Instruct-2503",
            "revision": "main",
            "required": false,
            "local_dir": "llm/mistral_small_3_1",
            "gated": true,
            "license_url": "https://huggingface.co/mistralai/Mistral-Small-3.1-24B-Instruct-2503",
            "license_note": "Gated model. Accept Mistral terms at the URL above. Requires ~55GB VRAM in bf16. NOT a diffusion text encoder; used only for optional prompt enrichment via --enrich-prompts flag in run_scenarios.py.",
            "download": {
                "mode": "snapshot",
                "allow_patterns": [
                    "*.safetensors",
                    "*.json",
                    "*.model",
                    "*.txt"
                ]
            }
        }
    ]
}
